# Worktrees are now in /tmp — ignore any remnants here
worktrees/
brain/mythos_profiling_input.json

# json_safety.py runtime artifacts: <file>.lock sidecars (one per locked
# JSON file, created on first write), <file>.bak (last-known-good rollover
# on every atomic write), <file>.corrupt-<timestamp> (forensic copies made
# only when a corrupt read is detected — should be rare, but never commit
# one if it appears; investigate it instead).
*.lock
*.json.bak
*.corrupt-*
